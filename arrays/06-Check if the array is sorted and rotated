class Solution {
    public boolean check(int[] nums) {
        int count = 0;
        int n = nums.length;
        
        for (int i = 0; i < n; i++) {
            // Compare each element with the next one (using modulo for wrap-around)
            // If the current element is greater than the next, it's a "break"
            if (nums[i] > nums[(i + 1) % n]) {
                count++;
            }
            
            // If more than 1 break is found, it cannot be a sorted rotated array
            if (count > 1) return false;
        }
        
        return true;
    }
}
