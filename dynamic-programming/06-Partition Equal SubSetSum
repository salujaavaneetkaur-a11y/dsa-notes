Partition Equal SubSet Sum

class Solution {
    public boolean canPartition(int[] nums) {
        int totalSum = 0;
        for (int num : nums) {
            totalSum += num;
        }

        // If total sum is odd, it cannot be partitioned into two equal integers
        if (totalSum % 2 != 0) return false;

        int target = totalSum / 2;
        int n = nums.length;
        
        // dp[i][j] will be true if sum j can be formed by first i elements
        boolean[][] dp = new boolean[n + 1][target + 1];

        // Base case: A sum of 0 can always be formed with an empty subset
        for (int i = 0; i <= n; i++) {
            dp[i][0] = true;
        }

        // Fill the DP table
        for (int i = 1; i <= n; i++) {
            int currentNum = nums[i - 1];
            for (int j = 1; j <= target; j++) {
                if (j < currentNum) {
                    // Current number is too large, inherit result from previous elements
                    dp[i][j] = dp[i - 1][j];
                } else {
                    // Either exclude currentNum or include it (if sum j - currentNum is possible)
                    dp[i][j] = dp[i - 1][j] || dp[i - 1][j - currentNum];
                }
            }
        }

        return dp[n][target];
    }
}

Time Complexity: O(n * target)
Space Complexity: O(n * target) 